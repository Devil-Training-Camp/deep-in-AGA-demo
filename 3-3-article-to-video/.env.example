# 复制为 .env 后填入真实 Key（.env 已 gitignore，不提交）

# Claude（步骤 2 改写 / 步骤 3 分镜）
ANTHROPIC_API_KEY=
# 可选：自定义 Anthropic API 地址，转发到你自己的中转/代理服务器（留空则用官方默认）。
# SDK 会在其后拼 /v1/messages，所以填到 base 即可，如 https://your-proxy.com 或 https://your-proxy.com/anthropic
ANTHROPIC_BASE_URL=

# ElevenLabs（步骤 4 TTS + 字符级时间戳）
ELEVENLABS_API_KEY=
