# Anthropic (Claude API)
# 需要同时配置 base URL 和 auth token，否则 API 调用会失败
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_AUTH_TOKEN=

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=
# 语音 ID，默认 Adam（支持中文），建议在 ElevenLabs Playground 试听后替换
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# 视频生成（完整版 B-roll，MVP 阶段可不填）
# Seedance（字节/火山引擎）—— 优先验证
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_SECRET_KEY=
# Kling 2.0（快手）—— 备选
KLING_API_KEY=
# Runway Gen-3 —— 保底
RUNWAY_API_KEY=

# 视频输出规格（默认值已可用，按需覆盖）
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=30
